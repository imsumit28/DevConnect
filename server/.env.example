PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Comma-separated allowed frontend origins for CORS (first value used for OAuth redirects)
CLIENT_URL=http://localhost:5173

# Optional explicit server base URL (used in uploaded file links)
SERVER_URL=http://localhost:5000

# Optional SMTP settings for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

